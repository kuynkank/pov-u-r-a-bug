{
    "manifest_version": 3,
    "name": "Close Up Online",
    "version": "1.0",
    "description": "Seeing everything up close",
    "permissions": ["storage"],
    "web_accessible_resources": [
        {
          "resources": ["ladybug.png"],
          "matches": ["<all_urls>"]
        }
    ],
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ],
    "action": {
      "default_title": "Close Up"
    }
  }