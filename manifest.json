{
    "manifest_version": 3,
    "name": "POV: You're A Bug",
    "version": "1.0",
    "description": "Seeing everything up close",
    "web_accessible_resources": [
        {
          "resources": ["ladybug.png"],
          "matches": ["<all_urls>"]
        }
    ],
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ],
    "icons": {
      "16": "ladybug.png",
      "48": "ladybug.png",
      "128": "ladybug.png"
    },
    "action": {
      "default_title": "POV: You're A Bug",
      "default_icon": "ladybug.png",
      "default_popup": "popup.html"
    },
    "permissions": ["storage", "tabs"]
  }